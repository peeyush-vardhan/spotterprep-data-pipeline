# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.
#
# Find your account identifier in Snowflake:
#   Admin → Accounts → hover over your account → copy the locator
#   Format: <locator>.<region>  e.g. xy12345.us-east-1
#   For Azure: xy12345.east-us-2.azure
#   For GCP:   xy12345.us-central1.gcp

SNOWFLAKE_ACCOUNT=<account_locator>.<region>
SNOWFLAKE_USER=<your_username>
SNOWFLAKE_PASSWORD=<your_password>
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=SYSADMIN
